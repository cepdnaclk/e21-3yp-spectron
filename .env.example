DB_HOST=localhost
DB_PORT=5432
DB_NAME=spectron
DB_USER=spectron
DB_PASSWORD=change_me

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPTION_KEY=change_this_long_random_backup_key
APP_ENCRYPTION_KEY=change_this_32_byte_key

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=spectron-backend
KAFKA_TLS_ENABLED=false
KAFKA_MTLS_ENABLED=false
KAFKA_CA_CERT_PATH=./certs/ca.pem
KAFKA_CLIENT_CERT_PATH=./certs/client.pem
KAFKA_CLIENT_KEY_PATH=./certs/client-key.pem
KAFKA_INSECURE_SKIP_VERIFY=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=change_me
EMAIL_FROM="Spectron <no-reply@example.com>"
FRONTEND_URL=http://localhost:3001

# Farm location search and reverse geocoding.
# Default works with OpenStreetMap Nominatim; use your provider URL/key in production.
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_API_KEY=
GEOCODING_USER_AGENT=SpectronAgriAssist/1.0
GEOCODING_TIMEOUT_MS=8000

# Hosted AI for normal sensor configuration and AgriAssist.
# OPENROUTER_API_KEY auto-selects OpenRouter even when AI_PROVIDER is unset.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://spectroniot.xyz
OPENROUTER_APP_TITLE=Spectron
OPENROUTER_TIMEOUT_MS=30000
