# Copy to `.env` and adjust. Restart `npm start` after edits.

# Dev server port (optional; default 3000).
PORT=3001
# Webpack dev server websocket port when behind a proxy or custom port.
WDS_SOCKET_PORT=3001

# Backend API base URL (no trailing slash).
Local: http://localhost:8080 or http://localhost:8081
REACT_APP_API_URL=http://spectron-backend-env.eba-niaes6bi.ap-south-1.elasticbeanstalk.com

# Optional: mock hardware pairing when developing without devices (set to "true" to enable).
# REACT_APP_MOCK_MODE=false
# REACT_APP_HARDWARE_MOCK=false
# REACT_APP_MOCK_HARDWARE=false
