{
  "info": {
    "_postman_id": "07e4b7cf-4ce1-4fb9-8e1c-394a3d414f88",
    "name": "Spectron Authentication API",
    "description": "Postman collection for testing the Spectron authentication backend at http://localhost:8080. Login stores the returned JWT in the collection variable named token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Success Flow",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let responseJson;",
                  "try {",
                  "  responseJson = pm.response.json();",
                  "} catch (error) {}",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "  pm.expect(responseJson, \"parsed JSON body\").to.not.equal(undefined);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let responseJson;",
                  "try {",
                  "  responseJson = pm.response.json();",
                  "} catch (error) {}",
                  "",
                  "if (responseJson && responseJson.token) {",
                  "  pm.collectionVariables.set(\"token\", responseJson.token);",
                  "}",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "  pm.expect(responseJson, \"parsed JSON body\").to.not.equal(undefined);",
                  "});",
                  "",
                  "pm.test(\"JWT token exists and is saved\", function () {",
                  "  pm.expect(responseJson, \"response JSON\").to.be.an(\"object\");",
                  "  pm.expect(responseJson.token, \"response token\").to.be.a(\"string\").and.have.lengthOf.above(0);",
                  "  pm.expect(pm.collectionVariables.get(\"token\"), \"collection token\").to.eql(responseJson.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let responseJson;",
                  "try {",
                  "  responseJson = pm.response.json();",
                  "} catch (error) {}",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "  pm.expect(responseJson, \"parsed JSON body\").to.not.equal(undefined);",
                  "});",
                  "",
                  "pm.test(\"Current user email matches test user\", function () {",
                  "  pm.expect(responseJson, \"response JSON\").to.be.an(\"object\");",
                  "  pm.expect(responseJson.email).to.eql(pm.collectionVariables.get(\"email\"));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Current User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirm_email\": \"{{email}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let responseJson;",
                  "try {",
                  "  responseJson = pm.response.json();",
                  "} catch (error) {}",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "  pm.expect(responseJson, \"parsed JSON body\").to.not.equal(undefined);",
                  "});",
                  "",
                  "pm.test(\"Account was deleted\", function () {",
                  "  pm.expect(responseJson, \"response JSON\").to.be.an(\"object\");",
                  "  pm.expect(responseJson.status).to.eql(\"account_deleted\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Unauthorized Checks",
      "item": [
        {
          "name": "Get Current User - Missing Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Unauthorized route returns 401 when token is missing\", function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Current User - Missing Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirm_email\": \"{{email}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Unauthorized route returns 401 when token is missing\", function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "name",
      "value": "Tithurshan",
      "type": "string"
    },
    {
      "key": "email",
      "value": "tithurshan@test.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "12345678",
      "type": "string"
    }
  ]
}
